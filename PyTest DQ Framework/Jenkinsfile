pipeline {

    agent any

    stages {

        stage('Checkout') {

            steps {

                checkout scm

            }

        }

        stage('Install & Test') {

            steps {

                sh '''

                python3 -m pip install --break-system-packages --upgrade pip || true

                pip3 install --break-system-packages -r requirements.txt || true

                mkdir -p html_report || true

                pytest tests -s -m parquet_data \

                  --html=html_report/report.html \

                  --self-contained-html || true

                '''

            }

        }

        stage('Archive Report') {

            steps {

                archiveArtifacts artifacts: 'html_report/**', allowEmptyArchive: true

                script {

                    if (fileExists('html_report/report.html')) {

                        publishHTML(target: [

                            allowMissing: false,

                            keepAll: true,

                            reportDir: 'html_report',

                            reportFiles: 'report.html',

                            reportName: 'PyTest Report'

                        ])

                    } else {

                        echo "No report generated"

                    }

                }

            }

        }

    }

    post {

        always {

            echo "Pipeline finished"

        }

    }

}
 