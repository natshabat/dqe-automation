pipeline {
   agent any
   environment {
       POSTGRES_SECRET = credentials('postgres-secret')
   }
   stages {
       stage('Checkout') {
           steps {
               checkout scm
           }
       }
       stage('Run tests') {
           steps {
               sh '''
                   mkdir -p html_report
                   pytest tests -s -m parquet_data \
                     --db_host=localhost \
                     --db_port=5434 \
                     --db_name=mydatabase \
                     --db_user=myuser \
                     --db_password=myuser \
                     --html=html_report/report.html \
                     --self-contained-html
               '''
           }
       }
       stage('Archive') {
           steps {
               archiveArtifacts artifacts: 'html_report/**', allowEmptyArchive: true
           }
       }
   }
}