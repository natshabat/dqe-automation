pipeline {
   agent any
   environment {
       POSTGRES_SECRET = credentials('postgres-secret')
   }
   stages {
       stage('Checkout') {
           steps {
               checkout scm
           }
       }
       stage('Install dependencies') {
           steps {
               sh '''
               python3 -m pip install --upgrade pip
               pip3 install -r requirements.txt
               '''
           }
       }
       stage('Run tests') {
           steps {
               sh '''
               pytest tests -s -m parquet_data \
                 --db_host=localhost \
                 --db_port=5434 \
                 --db_name=mydatabase \
                 --db_user=$POSTGRES_SECRET_USR \
                 --db_password=$POSTGRES_SECRET_PSW \
                 --html=html_report/report.html \
                 --self-contained-html
               '''
           }
       }
       stage('Archive Test Report') {
           steps {
               archiveArtifacts artifacts: 'html_report/**', allowEmptyArchive: true
           }
       }
   }
}