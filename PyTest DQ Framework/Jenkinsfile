pipeline {
   agent any

   environment {
       POSTGRES_SECRET = credentials('postgres-secret')
       DB_HOST = 'localhost'
       DB_PORT = '5434'
       DB_NAME = 'mydatabase'
       PYTHONPATH = "${WORKSPACE}"
   }

   stages {

       stage('Checkout') {
           steps {
               checkout scm
           }
       }

       stage('Verify environment') {
           steps {
               sh '''
               python3 --version || true
               pip3 --version || true
               whoami
               '''
           }
       }

       stage('Install dependencies') {
           steps {
               sh '''
               python3 -m pip install --upgrade pip
               pip3 install -r requirements.txt
               '''
           }
       }

       stage('Run tests') {
           steps {
               sh '''
               pytest tests -s -m parquet_data \
                 --db_host=$DB_HOST \
                 --db_port=$DB_PORT \
                 --db_name=$DB_NAME \
                 --db_user=$POSTGRES_SECRET_USR \
                 --db_password=$POSTGRES_SECRET_PSW \
                 --html=html_report/report.html \
                 --self-contained-html \
                 --junitxml=report.xml
               '''
           }
       }

       stage('Archive reports') {
           steps {
               archiveArtifacts artifacts: 'html_report/**', allowEmptyArchive: true
               junit 'report.xml'
           }
       }
   }

   post {
       always {
           echo "Pipeline finished"
       }
   }
}