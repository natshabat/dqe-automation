pipeline {
   agent any

   environment {
       POSTGRES_SECRET = credentials('postgres-secret')
       PROJECT_DIR = "PyTest DQ Framework"
   }

   stages {

       stage('Checkout') {
           steps {
               checkout scm
           }
       }

       stage('Verify') {
           steps {
               sh '''
               python3 --version
               pip3 --version
               '''
           }
       }

       stage('Install dependencies') {
           steps {
               sh '''
               cd "$PROJECT_DIR"
               python3 -m venv venv
               . venv/bin/activate

               pip install --upgrade pip
               pip install -r "requirements.txt"
               '''
           }
       }

       stage('Run tests') {
           steps {
               sh '''
               cd "$PROJECT_DIR"
               . venv/bin/activate

               pytest tests -s -m parquet_data \
                  --db_host=host.docker.internal \
                  --db_port=5434 \
                  --db_name=mydatabase \
                  --db_user=$POSTGRES_SECRET_USR \
                  --db_password=$POSTGRES_SECRET_PSW \
                  --html=html_report/report.html \
                  --junitxml=report.xml
               '''
           }
       }

       stage('Archive') {
           steps {
               archiveArtifacts artifacts: 'PyTest DQ Framework/html_report/**', allowEmptyArchive: true
               junit 'PyTest DQ Framework/report.xml'

               publishHTML(target: [
                allowMissing: false,
                keepAll: true,
                reportDir: 'PyTest DQ Framework/html_report',
                reportFiles: 'report.html',
                reportName: 'HTML Test Report'
                ])
           }
       }
   }
}